# Core mailbox credentials
EMAIL_ADDRESS=your.email@example.com
EMAIL_APP_PASSWORD=your-app-password

# SMTP settings (outgoing email through your provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# IMAP settings (incoming email sync and auto scan)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_FOLDER=INBOX

# App behavior
AUTO_SYNC_ON_START=false
APP_HOST=0.0.0.0
APP_PORT=5000
QUIET_STARTUP=true

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=emailserver
DB_USER=postgres
DB_PASSWORD=your-db-password

# Local SMTP server (user@local.com → user@local.com)
LOCAL_SMTP_HOST=127.0.0.1
LOCAL_SMTP_PORT=1025
LOCAL_DOMAIN=local.com

# Phishing detection threshold (0.60 = tuned to reduce false positives)
PHISHING_THRESHOLD=0.60
TRUSTED_DOMAIN_REDUCTION=0.18

# Optional: Add your VirusTotal API key for domain reputation checks
VIRUSTOTAL_API_KEY=

